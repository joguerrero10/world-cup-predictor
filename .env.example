# ── Base de datos ──────────────────────────────────────────────────────────
POSTGRES_USER=wcp
POSTGRES_PASSWORD=change_me
POSTGRES_DB=worldcup
DATABASE_URL=postgresql+psycopg2://wcp:change_me@db:5432/worldcup

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API ────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
API_WORKERS=2

# ── Workers ────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
WORKER_CPU_LIMIT=4
WORKER_MEM_LIMIT=4G

# ── Proveedores de datos ────────────────────────────────────────────────────
# football-data.org — clave GRATUITA en https://www.football-data.org/client/register
# Sin clave, el sistema usa solo CSV locales como fuente de datos.
FOOTBALL_DATA_API_KEY=ffe7e2b7c6634fb7b6965f12dd6d1c49

# Activar/desactivar proveedores individuales (true/false)
PROVIDER_FOOTBALL_DATA_ORG_ENABLED=true
PROVIDER_WORLD_BANK_ENABLED=true
PROVIDER_LOCAL_CSV_ENABLED=true

# ── Pesos del modelo híbrido (Klement 2.0 puede aprender estos valores) ───
W_KLEMENT=0.30
W_ELO=0.40
W_DIXON_COLES=0.20
W_FORM=0.10
